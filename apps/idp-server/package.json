{
  "name": "@idp/idp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "retention:run": "tsx src/jobs/run-data-retention.ts",
    "retention:dry-run": "tsx src/jobs/run-data-retention.ts --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome check src",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@idp/auth-core": "workspace:*",
    "@idp/db": "workspace:*",
    "@idp/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/instrumentation-ioredis": "^0.63.0",
    "@opentelemetry/instrumentation-pg": "^0.67.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "argon2": "^0.43.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.7",
    "oidc-provider": "^9.5.1",
    "pino": "^9.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@vitest/coverage-v8": "^3.1.2",
    "msw": "^2.8.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
