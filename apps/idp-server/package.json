    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.0",
    "msw": "^2.8.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
